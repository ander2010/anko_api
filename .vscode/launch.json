{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Uvicorn ASGI (anko_core)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "anko_core.asgi:application",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "django": false,
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Django Runserver",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver",
        "0.0.0.0:8000"
      ],
      "django": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
