{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Daphne ASGI (anko_core)",
      "type": "python",
      "request": "launch",
      "module": "daphne",
      "args": [
        "-b",
        "0.0.0.0",
        "-p",
        "8000",
        "anko_core.asgi:application"
      ],
      "django": false,
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    },
    {
      "name": "Django Runserver",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver",
        "0.0.0.0:8000"
      ],
      "django": true,
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
